{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Run as Module",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "autoReload": {
        "enable": true
      },

      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
